---
// "Markdown with superpowers." — MDX source on the left, the rendered
// output on the right. The rendered side leans on the real shipped <CodeBlock>
// and <Callout> so the preview is genuinely Blume-rendered, not a look-alike.
import Callout from "blume/components/content/Callout.astro";
import CodeBlock from "blume/components/content/CodeBlock.astro";
import Icon from "blume/components/Icon.astro";
import CopyGlyph from "./CopyGlyph.astro";

// Declared as a string and rendered through an Astro expression so the
// Markdown inside auto-escapes (no hand-written entities).
const showcaseSource = `---
title: Installation
---

Install **Blume**, then create a config file:

\`\`\`package-install
blume
\`\`\`

\`\`\`ts title="blume.config.ts"
export default {
  title: "Docs",
};
\`\`\`

:::tip
Search, theming, and navigation
work out of the box.
:::

| Feature | Status |
| ------- | ------ |
| Search  | Ready  |
| Theming | Ready  |`;

// The config fence, highlighted for real on the rendered side.
const configCode = `export default {
  title: "Docs",
};`;
const packageManagers = ["npm", "pnpm", "yarn", "bun"];
---

<!-- Write Markdown. Render components. -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      Markdown with superpowers.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Directives become callouts, a package name becomes install tabs, and
      fenced code gets highlighted — no imports, no JSX to manage.
    </p>
  </div>
  <div
    class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-blume border border-border bg-background"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2">
      <!-- Source -->
      <pre
        class="overflow-x-auto p-5 font-mono text-foreground text-xs leading-relaxed sm:text-[13px]"><code>{showcaseSource}</code></pre>
      <!-- Rendered: divider sits above it when stacked, left of it at lg. -->
      <div class="border-border border-t p-5 sm:p-6 lg:border-t-0 lg:border-l">
        <h3 class="font-semibold text-foreground text-lg tracking-tight">
          Installation
        </h3>
        <p class="mt-3 text-muted-foreground text-sm">
          Install <strong class="font-semibold text-foreground">Blume</strong>,
          then create a config file:
        </p>
        <div class="mt-3 overflow-hidden rounded-blume border border-border">
          <div
            class="flex items-center gap-4 border-border border-b bg-muted/40 px-4 text-xs"
          >
            {
              packageManagers.map((pm, i) => (
                <span
                  class={`border-b-2 py-2 ${i === 0 ? "border-accent text-foreground" : "border-transparent text-muted-foreground"}`}
                >
                  {pm}
                </span>
              ))
            }
          </div>
          <div
            class="flex items-center justify-between px-4 py-3 font-mono text-foreground text-xs"
          >
            <span><span class="text-muted-foreground">npm</span> install blume</span
            >
            <Icon class="size-3.5 text-muted-foreground" name="copy" size={14} />
          </div>
        </div>
        <div class="relative mt-4 [&_pre]:my-0!">
          <CodeBlock code={configCode} icons lang="ts" title="blume.config.ts" />
          <CopyGlyph />
        </div>
        <Callout type="tip">
          Search, theming, and navigation work out of the box.
        </Callout>
        <table class="mt-2 w-full border-collapse text-left text-sm">
          <thead>
            <tr class="border-border border-b text-muted-foreground">
              <th class="py-2 pr-4 font-medium">Feature</th>
              <th class="py-2 font-medium">Status</th>
            </tr>
          </thead>
          <tbody class="text-foreground">
            <tr class="border-border border-b">
              <td class="py-2 pr-4">Search</td>
              <td class="py-2">Ready</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">Theming</td>
              <td class="py-2">Ready</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
