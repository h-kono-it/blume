---
// "Every component you need." — a compact three-column index of the built-in
// component library, in the style of x.ai/cli's "Everything you need to ship":
// a faint monochrome icon beside a title and a one-line blurb. Each item links
// to its section on the components reference page. Icons are Lucide-style paths
// kept local to this section (the shipped icon set is intentionally small, and
// this grid wants one glyph per component).

const componentsHref = "/docs/content/components";

// One entry per component documented in content/docs/content/components.mdx.
// `href` targets the github-slugger anchor Blume generates for each heading, so
// clicking an item jumps straight to that component's live example.
const components = [
  {
    description: "Linked cards with an icon, in a responsive grid",
    href: `${componentsHref}#card-and-cardgroup`,
    icon: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
    title: "Card & CardGroup",
