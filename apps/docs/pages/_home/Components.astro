---
// "Every component you need." — a compact three-column index of the built-in
// component library, in the style of x.ai/cli's "Everything you need to ship":
// a faint monochrome icon beside a title and a one-line blurb. Each item links
// to its section on the components reference page. Each `icon` is a Lucide name
// resolved to inline SVG at build time via `glyph` (see _home/shared.ts).
import { glyph } from "./shared.ts";

const componentsHref = "/docs/content/components";

// One entry per component documented in content/docs/content/components.mdx.
// `href` targets the github-slugger anchor Blume generates for each heading, so
// clicking an item jumps straight to that component's live example.
const components = [
  {
    description: "Linked cards with an icon, in a responsive grid",
    href: `${componentsHref}#card-and-cardgroup`,
    icon: glyph("layout-grid"),
    title: "Card & CardGroup",
  },
  {
    description: "A numbered sequence for ordered instructions",
    href: `${componentsHref}#steps`,
    icon: glyph("list-ordered"),
    title: "Steps",
  },
  {
    description: "Switch between equivalent content in place",
    href: `${componentsHref}#tabs`,
    icon: glyph("app-window"),
    title: "Tabs",
  },
  {
    description: "Inline labels for status and metadata",
    href: `${componentsHref}#badge`,
    icon: glyph("badge"),
    title: "Badge",
  },
  {
    description: "Render a project layout from a Markdown list",
    href: `${componentsHref}#file-tree`,
    icon: glyph("folder-tree"),
    title: "File tree",
  },
  {
    description: "Stacked collapsibles in one bordered container",
    href: `${componentsHref}#accordion`,
    icon: glyph("rows-3"),
    title: "Accordion",
  },
  {
    description: "A lightweight inline disclosure for detail",
    href: `${componentsHref}#expandable`,
    icon: glyph("unfold-vertical"),
    title: "Expandable",
  },
  {
    description: "Lay blocks out in a responsive column grid",
    href: `${componentsHref}#columns`,
    icon: glyph("columns-2"),
    title: "Columns",
  },
  {
    description: "Group code blocks into a tabbed switcher",
    href: `${componentsHref}#codegroup`,
    icon: glyph("code-xml"),
    title: "CodeGroup",
  },
  {
    description: "Center and caption an image or visual",
    href: `${componentsHref}#frame`,
    icon: glyph("frame"),
    title: "Frame",
  },
  {
    description: "A hierarchy with expandable folders",
    href: `${componentsHref}#tree`,
    icon: glyph("list-tree"),
    title: "Tree",
  },
  {
    description: "A titled container for set-aside content",
    href: `${componentsHref}#panel`,
    icon: glyph("layout-panel-top"),
    title: "Panel",
  },
  {
    description: "Reveal a definition or hint on hover",
    href: `${componentsHref}#tooltip`,
    icon: glyph("message-square-text"),
    title: "Tooltip",
  },
  {
    description: "A clickable preview that leads with a visual",
    href: `${componentsHref}#tile`,
    icon: glyph("layout-template"),
    title: "Tile",
  },
  {
    description: "A copyable prompt with a copy button",
    href: `${componentsHref}#prompt`,
    icon: glyph("square-terminal"),
    title: "Prompt",
  },
  {
    description: "Show or hide content by audience",
    href: `${componentsHref}#visibility`,
    icon: glyph("eye"),
    title: "Visibility",
  },
  {
    description: "Document an object's props, types, and defaults",
    href: `${componentsHref}#type-tables`,
    icon: glyph("table-2"),
    title: "Type tables",
  },
  {
    description: "A repo card with live star and fork counts",
    href: `${componentsHref}#github-info`,
    icon: glyph("github"),
    title: "GitHub info",
  },
  {
    description: "Live preview of an example beside its source",
    href: `${componentsHref}#component`,
    icon: glyph("component"),
    title: "Component",
  },
  {
    description: "Shiki-highlighted code anywhere a fence can't go",
    href: `${componentsHref}#codeblock`,
    icon: glyph("square-code"),
    title: "CodeBlock",
  },
  {
    description: "A git-style, syntax-highlighted diff",
    href: `${componentsHref}#diff`,
    icon: glyph("diff"),
    title: "Diff",
  },
];
---

<!-- Component library index: x.ai/cli-style three-column grid of icon + title + blurb. -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-medium text-3xl tracking-tight sm:text-4xl">
      Every component you need.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-balance text-muted-foreground">
      An accessible, themeable component set — cards, steps, tabs, code groups,
      diffs, and more — usable in any .mdx page with nothing to import.
    </p>
  </div>

  <ul
    class="mx-auto mt-12 grid max-w-6xl list-none gap-x-12 gap-y-8 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      components.map((component) => (
        <li>
          <a class="group flex items-start gap-3" href={component.href}>
            <span class="mt-0.5 shrink-0 text-muted-foreground/50 transition-colors group-hover:text-accent">
              <svg
                class="size-[18px]"
                fill="none"
                height="18"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="18"
                set:html={component.icon}
              />
            </span>
            <span>
              <span class="block font-medium text-foreground text-sm transition-colors group-hover:text-accent">
                {component.title}
              </span>
              <span class="mt-0.5 block text-muted-foreground text-xs leading-relaxed">
                {component.description}
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="mt-12 text-center">
    <a
      class="inline-flex items-center gap-1.5 rounded-blume border border-border px-5 py-3 font-medium text-foreground text-sm transition-colors hover:bg-muted"
      href={componentsHref}
    >
      Browse all components
      <svg
        class="size-4"
        fill="none"
        height="16"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="16"
        set:html={glyph("chevron-right")}
      />
    </a>
  </div>
</section>
