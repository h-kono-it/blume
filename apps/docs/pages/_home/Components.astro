    icon: '<path d="M15.536 11.293a1 1 0 0 0 0 1.414l2.376 2.377a1 1 0 0 0 1.414 0l2.377-2.377a1 1 0 0 0 0-1.414l-2.377-2.376a1 1 0 0 0-1.414 0z"/><path d="M2.297 11.293a1 1 0 0 0 0 1.414l2.377 2.377a1 1 0 0 0 1.414 0l2.377-2.377a1 1 0 0 0 0-1.414L6.088 8.917a1 1 0 0 0-1.414 0z"/><path d="M8.916 17.912a1 1 0 0 0 0 1.415l2.377 2.376a1 1 0 0 0 1.414 0l2.377-2.376a1 1 0 0 0 0-1.415l-2.377-2.376a1 1 0 0 0-1.414 0z"/><path d="M8.916 4.674a1 1 0 0 0 0 1.414l2.377 2.376a1 1 0 0 0 1.414 0l2.377-2.376a1 1 0 0 0 0-1.414L12.707 2.297a1 1 0 0 0-1.414 0z"/>',
    title: "Component",
  },
  {
    description: "Shiki-highlighted code anywhere a fence can't go",
    href: `${componentsHref}#codeblock`,
    icon: '<path d="M10 9.5 8 12l2 2.5"/><path d="m14 9.5 2 2.5-2 2.5"/><rect width="18" height="18" x="3" y="3" rx="2"/>',
    title: "CodeBlock",
  },
  {
    description: "A git-style, syntax-highlighted diff",
    href: `${componentsHref}#diff`,
    icon: '<path d="M12 3v14"/><path d="M5 10h14"/><path d="M5 21h14"/>',
    title: "Diff",
