---
interface Parameter {
  name: string;
  type?: string;
  required?: boolean;
  description?: string;
}

interface Props {
  title?: string;
  parameters?: Parameter[];
}

const { title, parameters = [] } = Astro.props;
---

<div class="not-prose my-6">
  {title && <p class="mb-2 font-medium text-foreground">{title}</p>}
  {
    parameters.length > 0 && (
      <div class="overflow-hidden rounded-blume border border-border">
        <table class="w-full border-separate border-spacing-0 text-sm [&_tbody_tr:last-child_td]:border-b-0">
          <thead class="bg-muted/35">
            <tr>
              <th class="border-border border-b px-3 py-2 text-left font-medium">
                Name
              </th>
              <th class="border-border border-b px-3 py-2 text-left font-medium">
                Type
              </th>
              <th class="border-border border-b px-3 py-2 text-left font-medium">
                Description
              </th>
            </tr>
          </thead>
          <tbody>
            {parameters.map((parameter) => (
              <tr>
                <td class="border-border border-b px-3 py-2 align-top">
                  <code class="font-mono">{parameter.name}</code>
                  {parameter.required && (
                    <span class="ml-1.5 text-muted-foreground text-xs">
                      required
                    </span>
                  )}
                </td>
                <td class="border-border border-b px-3 py-2 align-top">
                  {parameter.type && (
                    <code class="font-mono text-muted-foreground">
                      {parameter.type}
                    </code>
                  )}
                </td>
                <td class="border-border border-b px-3 py-2 align-top text-muted-foreground">
                  {parameter.description}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
  <slot />
</div>
