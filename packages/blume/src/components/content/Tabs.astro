---
interface Props {
  borderBottom?: boolean;
  defaultTabIndex?: number;
  dropdown?: boolean;
  hash?: boolean | "false" | "true";
  /**
   * Render borderless — a tab strip on a full-width rule with the content
   * flowing beneath as prose — instead of the default bordered box. Reads as
   * page-level navigation rather than an isolated widget; pair with `param` for
   * shareable, multiple-per-page tabs.
   */
  inline?: boolean;
  /**
   * Sync the active tab to this URL query-param key instead of the hash. Each
   * group owns its own param, so several `Tabs` can share a page and every
   * selection is deep-linkable (`?install=windows`). Give each group a unique
   * `param`; it takes precedence over `hash`.
   */
  param?: string;
  sync?: boolean;
}

const {
  borderBottom = true,
  defaultTabIndex = 0,
  dropdown = false,
  hash = true,
  inline = false,
  param,
  sync = true,
} = Astro.props;

// MDX string attributes (`hash="false"` from generated markup) must read as
// their boolean meaning — the string "false" is truthy.
const hashEnabled = String(hash) !== "false";
// The dropdown (select) affordance belongs to the boxed layout; inline always
// renders a tab strip.
const useDropdown = dropdown && !inline;
---

<blume-tabs
  class:list={[
    "my-6 block",
    inline
      ? ""
      : "not-prose overflow-hidden rounded-blume border border-border bg-background",
  ]}
  data-border-bottom={borderBottom ? "true" : "false"}
  data-default-tab-index={defaultTabIndex}
  data-dropdown={useDropdown ? "true" : "false"}
  data-hash={hashEnabled ? "true" : "false"}
  data-param={param}
  data-sync={sync ? "true" : "false"}
>
  <div
    class:list={[
      inline ? "not-prose" : "",
      useDropdown ? "" : "overflow-x-auto",
    ]}
  >
    <div
      class:list={[
        useDropdown || borderBottom ? "border-border border-b" : "",
        useDropdown ? "p-3" : inline ? "flex gap-4" : "flex gap-4 px-3",
      ]}
      data-blume-tablist
      role={useDropdown ? undefined : "tablist"}
    >
    </div>
  </div>
  <div
    class:list={[inline ? "pt-4 [&>[data-blume-tab-panel]]:p-0!" : ""]}
    data-blume-tab-content
  >
    <slot />
  </div>
</blume-tabs>

<script>
  const TRIGGER_CLASS =
    "-mb-px inline-flex shrink-0 cursor-pointer items-center gap-1.5 border-transparent border-b-2 bg-transparent px-1 py-2.5 font-medium text-muted-foreground text-xs transition-colors hover:text-foreground aria-[selected=true]:border-accent aria-[selected=true]:text-foreground";
  const SELECT_CLASS =
    "w-full rounded-blume border border-border bg-background px-3 py-2 font-medium text-foreground text-sm";
  const SYNC_EVENT = "blume-tabs-change";

  // Disambiguates generated trigger/panel ids when the same tab labels appear
  // in several <Tabs> instances on one page.
  let instanceCount = 0;

  const panelTitle = (panel: HTMLElement, index: number) =>
    panel.dataset.title ?? `Tab ${index + 1}`;
  const panelId = (panel: HTMLElement) => panel.dataset.tabId ?? panel.id;
  const boundedIndex = (value: number, length: number) =>
    Math.min(Math.max(value, 0), Math.max(length - 1, 0));
  const appendTriggerContent = (
    trigger: HTMLButtonElement,
    panel: HTMLElement,
    index: number
  ) => {
    const icon = panel.querySelector<HTMLTemplateElement>(
      ":scope > template[data-blume-tab-icon]"
    );
    if (icon) {
      trigger.appendChild(icon.content.cloneNode(true));
    }
    const label = document.createElement("span");
    label.textContent = panelTitle(panel, index);
    trigger.appendChild(label);
  };

  class BlumeTabs extends HTMLElement {
    #panels: HTMLElement[] = [];
    #triggers: HTMLButtonElement[] = [];
    #select: HTMLSelectElement | null = null;

    connectedCallback() {
      const list = this.querySelector<HTMLElement>("[data-blume-tablist]");
      let panels = Array.from(
        this.querySelectorAll<HTMLElement>("[data-blume-tab-panel]")
      );
      // CodeGroup passes raw code fences instead of <Tab> elements, so adopt
      // the content wrapper's direct code blocks as panels. The tab label comes
      // from each block's title (the text after the language in the fence).
      if (panels.length === 0) {
        const wrapper = this.querySelector<HTMLElement>(
          ":scope > [data-blume-tab-content]"
        );
        const blocks = wrapper
          ? Array.from(wrapper.children).filter(
              (child): child is HTMLElement =>
                child instanceof HTMLElement && child.matches("pre, figure")
            )
          : [];
        for (const block of blocks) {
          block.setAttribute("data-blume-tab-panel", "");
        }
        panels = blocks;
      }
      if (!list || panels.length === 0) {
        return;
      }
      if (this.dataset.blumeTabsReady === "true") {
        // The built DOM survives a move; the listeners removed by
        // disconnectedCallback don't — re-attach them (addEventListener with
        // the same reference is idempotent).
        if (this.#syncEnabled()) {
          document.addEventListener(SYNC_EVENT, this.#sync);
        }
        this.#addUrlListener();
        return;
      }
      this.dataset.blumeTabsReady = "true";
      this.#panels = panels;

      if (this.dataset.dropdown === "true") {
        this.#select = document.createElement("select");
        this.#select.className = SELECT_CLASS;
        // Neutral default: tab sets aren't necessarily code examples.
        this.#select.setAttribute("aria-label", "Select tab");
        panels.forEach((panel, index) => {
          const option = document.createElement("option");
          option.value = String(index);
          option.textContent = panelTitle(panel, index);
          this.#select?.appendChild(option);
        });
        this.#select.addEventListener("change", () => {
          this.activate(Number(this.#select?.value ?? "0"), true, true);
        });
        list.appendChild(this.#select);
      } else {
        const instance = ++instanceCount;
        panels.forEach((panel, index) => {
          const trigger = document.createElement("button");
          trigger.type = "button";
          trigger.role = "tab";
          trigger.className = TRIGGER_CLASS;
          appendTriggerContent(trigger, panel, index);
          trigger.tabIndex = index === 0 ? 0 : -1;
          // Wire tab and panel both ways. An author-supplied panel id is kept;
          // otherwise derive unique ids from the label slug per instance.
          const slug = panelId(panel) || `tab-${index + 1}`;
          if (!panel.id) {
            panel.id = `blume-tabpanel-${slug}-${instance}`;
          }
          trigger.id = `blume-tab-${slug}-${instance}`;
          trigger.setAttribute("aria-controls", panel.id);
          panel.setAttribute("aria-labelledby", trigger.id);
          trigger.setAttribute(
            "aria-selected",
            index === 0 ? "true" : "false"
          );
          trigger.addEventListener("click", () => {
            this.activate(index, true, true);
          });
          trigger.addEventListener("keydown", (event) => {
            this.#onTriggerKeydown(event, index);
          });
          list.appendChild(trigger);
          this.#triggers.push(trigger);
          panel.classList.toggle("hidden", index !== 0);
        });
      }

      this.activate(this.#initialIndex(), false, false);
      if (this.#syncEnabled()) {
        document.addEventListener(SYNC_EVENT, this.#sync);
      }
      this.#addUrlListener();
    }

    disconnectedCallback() {
      document.removeEventListener(SYNC_EVENT, this.#sync);
      window.removeEventListener("hashchange", this.#urlChange);
      window.removeEventListener("popstate", this.#urlChange);
    }

    activate(index: number, sync: boolean, updateHash: boolean) {
      const activePanel = this.#panels[index];
      if (!activePanel) {
        return;
      }

      this.#panels.forEach((panel, panelIndex) => {
        panel.classList.toggle("hidden", panelIndex !== index);
      });
      this.#triggers.forEach((trigger, triggerIndex) => {
        trigger.setAttribute(
          "aria-selected",
          triggerIndex === index ? "true" : "false"
        );
        trigger.tabIndex = triggerIndex === index ? 0 : -1;
      });
      if (this.#select) {
        this.#select.value = String(index);
      }
      const id = panelId(activePanel);
      if (updateHash && id) {
        const param = this.#paramName();
        if (param) {
          // Query-param mode: write only this group's key, so several groups on
          // one page each deep-link independently. replaceState (not push) keeps
          // the shareable URL current without stacking a history entry per click.
          const url = new URL(window.location.href);
          url.searchParams.set(param, id);
          history.replaceState(history.state, "", url);
        } else if (this.#hashEnabled()) {
          history.replaceState(null, "", `#${encodeURIComponent(id)}`);
        }
      }
      if (sync && this.#syncEnabled()) {
        document.dispatchEvent(
          new CustomEvent(SYNC_EVENT, {
            detail: { title: panelTitle(activePanel, index) },
          })
        );
      }
    }

    activateByTitle(title: string, sync: boolean) {
      const index = this.#panels.findIndex((panel, panelIndex) => {
        return panelTitle(panel, panelIndex) === title;
      });
      if (index !== -1) {
        this.activate(index, sync, false);
      }
    }

    #activateByHash() {
      if (!this.#hashEnabled()) {
        return false;
      }
      const id = decodeURIComponent(window.location.hash.slice(1));
      if (!id) {
        return false;
      }
      const index = this.#panels.findIndex((panel) => panelId(panel) === id);
      if (index === -1) {
        return false;
      }

      this.activate(index, false, false);
      return true;
    }

    #activateByParam() {
      const param = this.#paramName();
      if (!param) {
        return false;
      }
      const value = new URL(window.location.href).searchParams.get(param);
      if (!value) {
        return false;
      }
      const index = this.#panels.findIndex((panel) => panelId(panel) === value);
      if (index === -1) {
        return false;
      }

      this.activate(index, false, false);
      return true;
    }

    #initialIndex() {
      const activated = this.#paramName()
        ? this.#activateByParam()
        : this.#activateByHash();
      if (activated) {
        return this.#panels.findIndex((panel) => !panel.classList.contains("hidden"));
      }
      return boundedIndex(
        Number(this.dataset.defaultTabIndex ?? "0"),
        this.#panels.length
      );
    }

    #onTriggerKeydown(event: KeyboardEvent, index: number) {
      const lastIndex = this.#triggers.length - 1;
      let nextIndex: number | undefined;
      if (event.key === "ArrowRight") {
        nextIndex = index === lastIndex ? 0 : index + 1;
      } else if (event.key === "ArrowLeft") {
        nextIndex = index === 0 ? lastIndex : index - 1;
      } else if (event.key === "Home") {
        nextIndex = 0;
      } else if (event.key === "End") {
        nextIndex = lastIndex;
      }
      if (nextIndex === undefined) {
        return;
      }

      event.preventDefault();
      this.activate(nextIndex, true, true);
      this.#triggers[nextIndex]?.focus();
    }

    #syncEnabled() {
      return this.dataset.sync !== "false";
    }

    #hashEnabled() {
      return this.dataset.hash !== "false";
    }

    #paramName() {
      return this.dataset.param || null;
    }

    // Query-param changes don't fire `hashchange`; they surface through history
    // navigation (`popstate`). Listen to whichever channel this group syncs on.
    #addUrlListener() {
      if (this.#paramName()) {
        window.addEventListener("popstate", this.#urlChange);
      } else {
        window.addEventListener("hashchange", this.#urlChange);
      }
    }

    #sync = (event: Event) => {
      const title = (event as CustomEvent<{ title?: string }>).detail?.title;
      if (title) {
        this.activateByTitle(title, false);
      }
    };

    #urlChange = () => {
      if (this.#paramName()) {
        this.#activateByParam();
      } else {
        this.#activateByHash();
      }
    };
  }

  if (!customElements.get("blume-tabs")) {
    customElements.define("blume-tabs", BlumeTabs);
  }
</script>
