---
// "Migrate in. Eject out." — bring an existing site in one command, or eject to
// a standalone Astro project. The copy buttons use the page-level delegated
// `data-blume-copy-install` handler in index.astro.
import { copyIcon, icons } from "./shared.ts";

const migrateCommand = "npx blume migrate mintlify";
const ejectCommand = "npx blume eject";
---

<!-- Migrate in. Eject out. -->
<section class="mx-auto max-w-4xl">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      Migrate in. Eject out.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Start from the docs you already have, and leave the day you want to — Blume
      is a starting point, not a cage.
    </p>
  </div>
  <div class="mt-12 grid gap-4 lg:grid-cols-2">
    <div class="rounded-blume border border-border p-6">
      <span
        class="inline-flex size-10 items-center justify-center rounded-blume bg-muted text-accent"
      >
        <svg
          class="size-5"
          fill="none"
          height="20"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="20"
          set:html={icons.migrate}
        ></svg>
      </span>
      <h3 class="mt-4 font-medium text-base text-foreground">
        Migrate in one command
      </h3>
      <p class="mt-2 text-muted-foreground text-sm leading-relaxed">
        Bring an existing site with one command. Content, navigation, and i18n are
        ported from Mintlify, Starlight, or Fumadocs.
      </p>
      <div
        class="mt-5 flex items-center gap-3 rounded-blume border border-border bg-muted/30 py-2 pr-2 pl-4"
      >
        <span
          aria-hidden="true"
          class="select-none font-mono text-muted-foreground text-sm">$</span
        >
        <code class="flex-1 truncate font-mono text-foreground text-sm"
          >{migrateCommand}</code
        >
        <button
          aria-label="Copy migrate command"
          class="inline-flex size-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          data-blume-copy-install
          data-command={migrateCommand}
          type="button"
        >
          <svg
            class="size-4"
            fill="none"
            height="16"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="16"
            set:html={copyIcon}
          ></svg>
        </button>
      </div>
    </div>
    <div class="rounded-blume border border-border p-6">
      <span
        class="inline-flex size-10 items-center justify-center rounded-blume bg-muted text-accent"
      >
        <svg
          class="size-5"
          fill="none"
          height="20"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="20"
          set:html={icons.eject}
        ></svg>
      </span>
      <h3 class="mt-4 font-medium text-base text-foreground">
        Eject when you're ready
      </h3>
      <p class="mt-2 text-muted-foreground text-sm leading-relaxed">
        Outgrew the defaults? Eject promotes the runtime to a standalone Astro
        project that still uses the blume package. No lock-in.
      </p>
      <div
        class="mt-5 flex items-center gap-3 rounded-blume border border-border bg-muted/30 py-2 pr-2 pl-4"
      >
        <span
          aria-hidden="true"
          class="select-none font-mono text-muted-foreground text-sm">$</span
        >
        <code class="flex-1 truncate font-mono text-foreground text-sm"
          >{ejectCommand}</code
        >
        <button
          aria-label="Copy eject command"
          class="inline-flex size-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          data-blume-copy-install
          data-command={ejectCommand}
          type="button"
        >
          <svg
            class="size-4"
            fill="none"
            height="16"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="16"
            set:html={copyIcon}
          ></svg>
        </button>
      </div>
    </div>
  </div>
</section>
