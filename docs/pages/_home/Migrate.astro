---
// "Migrate in one command." — bring an existing Mintlify, Fumadocs, Starlight,
// or Nextra site into Blume. The copy buttons use the page-level delegated
// `data-blume-copy-install` handler in index.astro.
import { copyIcon, icons } from "./shared.ts";

const tools = [
  {
    body: "Your docs.json (or mint.json) is translated to a blume.config.ts, every page is rewritten to idiomatic Blume MDX, and images are relocated alongside them — navigation, theming, and i18n come across with it.",
    command: "npx blume migrate mintlify",
    icon: icons.migrate,
    title: "From Mintlify",
  },
  {
    body: "Your content/docs tree moves into place and every meta.json becomes a typed meta.ts — frontmatter and folder ordering intact. Run blume dev and your pages are live.",
    command: "npx blume migrate fumadocs",
    icon: icons.fileCode,
    title: "From Fumadocs",
  },
  {
    body: "Your src/content/docs collection lands straight into place — Markdown, MDX, and Markdoc pages all come across with their frontmatter untouched, ready to render through Blume's components.",
    command: "npx blume migrate starlight",
    icon: icons.star,
    title: "From Starlight",
  },
  {
    body: "Your Nextra pages come across as Blume MDX and every _meta file becomes a typed meta.ts — navigation order and frontmatter intact. Run blume dev and your docs are live.",
    command: "npx blume migrate nextra",
    icon: icons.fileText,
    title: "From Nextra",
  },
];
---

<!-- Migrate in one command -->
<section class="mx-auto max-w-4xl">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      Migrate in one command.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Already have a docs site? Bring it across as-is. Blume reads your existing
      config and content and ports both into a working project — no copy-paste,
      no rebuild from scratch.
    </p>
  </div>
  <div class="mt-12 grid gap-4 sm:grid-cols-2">
    {
      tools.map((tool) => (
        <div class="rounded-blume border border-border p-6">
          <span class="inline-flex size-10 items-center justify-center rounded-blume bg-muted text-accent">
            <svg
              class="size-5"
              fill="none"
              height="20"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="20"
              set:html={tool.icon}
            />
          </span>
          <h3 class="mt-4 font-medium text-base text-foreground">{tool.title}</h3>
          <p class="mt-2 text-muted-foreground text-sm leading-relaxed">
            {tool.body}
          </p>
          <div class="mt-5 flex items-center gap-3 rounded-blume border border-border bg-muted/30 py-2 pr-2 pl-4">
            <span
              aria-hidden="true"
              class="select-none font-mono text-muted-foreground text-sm"
            >
              $
            </span>
            <code class="flex-1 truncate font-mono text-foreground text-sm">
              {tool.command}
            </code>
            <button
              aria-label={`Copy ${tool.title} command`}
              class="inline-flex size-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
              data-blume-copy-install
              data-command={tool.command}
              type="button"
            >
              <svg
                class="size-4"
                fill="none"
                height="16"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="16"
                set:html={copyIcon}
              />
            </button>
          </div>
        </div>
      ))
    }
  </div>
</section>
